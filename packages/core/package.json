{
  "name": "mayvio-ui",
  "version": "3.3.0",
  "description": "Modern, accessible and reusable UI components built with HTML, CSS and JavaScript.",
  "type": "module",
  "main": "./src/scripts/index.js",
  "exports": {
    ".": "./src/scripts/index.js",
    "./css": "./src/tokens/index.css",
    "./badge": "./src/components/badge/index.js",
    "./badge/css": "./src/components/badge/badge.css",
    "./alert": "./src/components/alert/index.js",
    "./alert/css": "./src/components/alert/alert.css",
    "./avatar": "./src/components/avatar/index.js",
    "./avatar/css": "./src/components/avatar/avatar.css",
    "./button": "./src/components/button/index.js",
    "./button/css": "./src/components/button/button.css",
    "./tooltip": "./src/components/tooltip/index.js",
    "./tooltip/css": "./src/components/tooltip/tooltip.css",
    "./toast": "./src/components/toast/index.js",
    "./toast/css": "./src/components/toast/toast.css",
    "./styles/*": "./src/styles/*",
    "./scripts/*": "./src/scripts/*"
  },
  "homepage": "https://github.com/mayur-dahake/mayvio-ui",
  "keywords": [
    "ui",
    "ui-components",
    "component-library",
    "design-system",
    "frontend",
    "html",
    "css",
    "javascript",
    "responsive",
    "accessibility",
    "dark-mode"
  ],
  "author": "Mayur Dahake",
  "license": "MIT"
}
